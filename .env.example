# Required: Claude API key for AI decision engine
ANTHROPIC_API_KEY=sk-ant-...

# Optional: OWS vault path (defaults to ~/.ows)
OWS_VAULT_PATH=

# Optional: x402 facilitator URL (defaults to https://facilitator.x402.org)
X402_FACILITATOR_URL=https://facilitator.x402.org

# Optional: Network (defaults to base-sepolia for testnet)
PAYMENT_NETWORK=base-sepolia

# Optional: Initial wallet balance for demo (in USDC, defaults to 10.00)
DEMO_WALLET_BALANCE=10.00

# Required for wallet connection (free from cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Optional: Vercel token for real deployments (get at vercel.com/account/tokens)
VERCEL_TOKEN=
